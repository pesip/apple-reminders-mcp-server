{
  "name": "apple-reminders-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Apple Reminders via AppleScript (no Full Disk Access needed)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "apple-reminders-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pesip/apple-reminders-mcp-server.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
